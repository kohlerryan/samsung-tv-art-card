// Copy this file to .vscode/settings.json and edit values for your machine.
// .vscode/settings.json is gitignored. The watch task in .vscode/tasks.json
// references these settings via ${config:samsungTvArtCard.deploy.*}, so each
// clone can target its own host/path without touching the committed file.
//
// The watch task runs scripts/watch_deploy.py (stdlib only) and works on
// Linux, macOS and Windows. Requirements per machine:
//   * Python on PATH (python3 on Linux/macOS, python on Windows)
//   * An SSH client on PATH (the OpenSSH client built into Windows 10/11,
//     macOS and Linux). rsync is used automatically if present, otherwise it
//     falls back to scp.
//
// Windows paths: use forward slashes and a drive letter, e.g.
//   "C:/Users/me/ha-www/community/samsung-tv-art-card/". Do not use ~ or $HOME.
{
    // SSH host alias or user@host serving the Home Assistant www folder
    "samsungTvArtCard.deploy.host": "your-host",
    // SSH port (use "22" if you don't run SSH on a non-standard port)
    "samsungTvArtCard.deploy.sshPort": "22",
    // Remote directory the card files (samsung-tv-art-card.js[.gz]) are synced into
    "samsungTvArtCard.deploy.path": "/path/to/homeassistant/config/www/community/samsung-tv-art-card/"
}
