{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch & Copy to samsung-tv-art-card",
            "type": "process",
            "command": "python3",
            "windows": {
                "command": "python"
            },
            "args": [
                "scripts/watch_deploy.py",
                "--label", "card",
                "--host", "${config:samsungTvArtCard.deploy.host}",
                "--port", "${config:samsungTvArtCard.deploy.sshPort}",
                "--remote-path", "${config:samsungTvArtCard.deploy.path}",
                "--gzip",
                "--watch", "samsung-tv-art-card.js"
            ],
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
