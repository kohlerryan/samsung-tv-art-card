{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Watch & Copy to samsung-tv-art-card",
            "type": "process",
            "command": "python3",
            "windows": {
                "command": "python"
            },
            "args": [
                "scripts/watch_deploy.py",
                "--label", "card",
                "--host", "${config:samsungTvArtCard.deploy.host}",
                "--port", "${config:samsungTvArtCard.deploy.sshPort}",
                "--remote-path", "${config:samsungTvArtCard.deploy.path}",
                "--gzip",
                "--watch", "samsung-tv-art-card.js"
            ],
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Sync Knowledge Base",
            "type": "process",
            "command": "${workspaceFolder:Knowledge Base}/bin/kb-sync.sh",
            "windows": {
                "command": "${config:samsungTvArtCard.kb.bashBin}",
                "args": [
                    "${workspaceFolder:Knowledge Base}/bin/kb-sync.sh"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder:Knowledge Base}",
                "env": {
                    "RKKB_KB_SYNC_INTERVAL": "${config:samsungTvArtCard.kb.syncInterval}"
                }
            },
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
